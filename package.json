{
  "name": "wechat-publisher",
  "version": "1.0.0",
  "description": "WeChat Post Publisher CLI",
  "main": "dist/index.js",
  "bin": {
    "wechat-pub": "dist/bin/wechat-pub.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/bin/wechat-pub.js",
    "start": "node dist/bin/wechat-pub.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write 'src/**/*.{ts,js}'"
  },
  "keywords": [],
  "author": "RbBtSn0w",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "form-data": "^4.0.5",
    "juice": "^10.0.1",
    "marked": "^12.0.2",
    "pako": "^2.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/form-data": "^2.2.1",
    "@types/marked": "^6.0.0",
    "@types/node": "^20.19.37",
    "@types/pako": "^2.0.4",
    "@types/yaml": "^1.9.7",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
